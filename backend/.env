# ============================================================
# HOPE_IRL — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env to version control.
# ============================================================

# ── Node ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── Database (PostgreSQL) ────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
DATABASE_URL=postgresql://postgres:7799@localhost:5432/hope_irl_db


# ── JWT Secrets (generate with: openssl rand -hex 64) ────────
JWT_ACCESS_SECRET=bd3998664b5d0756f68781137c6def010f9cb0cee5d43727751f94a6fa6fe29dcd4a76c6232efa09bee60ced6f00af72ab5adaf5bd8160ebaa22e2b1b810dcda
JWT_REFRESH_SECRET=andacfb09ad97d6c503d51075d9340d90ba54137a3d952f32a75b5a5951e69081b738e3a82b61185a0c4ed22851572115e5eee1471b05ca8314d568101abcb1edfb

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8080

# ── Email (NodeMailer / SMTP) ─────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=465
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME
EMAIL_FROM=noreply@hope-irl.com

# ── File Storage (Cloudflare R2 / AWS S3) ────────────────────
STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_BUCKET=hope-irl-documents
STORAGE_ACCESS_KEY=CHANGE_ME
STORAGE_SECRET_KEY=CHANGE_ME
STORAGE_REGION=auto

# ── Payment Gateway (Stripe) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME

# ── Security ─────────────────────────────────────────────────
# Number of bcrypt rounds (min 12 for production)
BCRYPT_ROUNDS=12
# Session cookie secret
COOKIE_SECRET=CHANGE_ME_32_CHAR_RANDOM
